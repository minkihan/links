{
  "manifest_version": 3,
  "name": "Links Bookmark",
  "version": "1.0",
  "description": "우클릭으로 Links 북마크에 추가",
  "permissions": ["contextMenus"],
  "host_permissions": ["http://127.0.0.1:9900/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": { "48": "icons/icon48.png" }
  },
  "icons": { "48": "icons/icon48.png" }
}
